# Generated by: npm run generate-wallets
# NEVER commit .env.wallets — this is just the template

TEST_MNEMONIC=

# RPC — use a private endpoint to avoid rate limits on heavy test runs
TEST_RPC_URL=https://base-sepolia.drpc.org

# Deployer private key — needed by seed-wallets to grant KYC + mint NUSD
# This is the 0x41521c37... deployer wallet that has all admin roles
